# 站点配置
NEXT_PUBLIC_SITE_URL=https://ka21.tools

# Microsoft Clarity (必需)
NEXT_PUBLIC_CLARITY_ID=your-clarity-project-id

# AI助手配置（可选）
NEXT_PUBLIC_ENABLE_AI_ASSISTANT=false
NEXT_PUBLIC_DEEPSEEK_API_KEY=your-deepseek-api-key
NEXT_PUBLIC_DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions

# 微信分享配置（可选；仅用于微信内 H5 右上角分享）
WECHAT_APP_ID=wx1234567890abcdef
WECHAT_APP_SECRET=your-wechat-app-secret

# 分析工具（可选）
# NEXT_PUBLIC_UMAMI_ID=your-umami-id
# NEXT_PUBLIC_BAIDU_ID=your-baidu-analytics-id

# GoAccess 离线报告配置（用于 npm run analytics:report）
# GOACCESS_LOG_PATH=/var/log/nginx/access.log,/var/log/nginx/access.log.1
# GOACCESS_LOG_FORMAT=COMBINED
# GOACCESS_DATE_FORMAT=%d/%b/%Y
# GOACCESS_TIME_FORMAT=%T
# GOACCESS_BIN=/opt/homebrew/bin/goaccess

# 开发环境配置
NODE_ENV=development

# GitHub API 配置（用于在线更新教程数据）
# 1. 在 GitHub Settings -> Developer settings -> Personal access tokens (Tokens (classic)) 申请
# 2. 权限勾选 'repo' (Full control of private repositories)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_REPO=Rosiawu/ka21
GITHUB_BRANCH=main
