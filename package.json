{
  "name": "ka21-tools",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:analyze": "ANALYZE=true next build",
    "start": "next start",
    "lint": "next lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "convert-icons": "node scripts/convert-icons.js",
    "optimize-images": "node scripts/optimize-images.js",
