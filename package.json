    "next-themes": "^0.4.6",
    "node-fetch": "^3.3.2",
    "react": "^18",
    "react-dom": "^18",
    "react-markdown": "^10.1.0",
    "sharp": "^0.34.4",
    "tesseract.js": "^7.0.0"
