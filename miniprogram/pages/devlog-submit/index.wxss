.page {
  min-height: 100vh;
  padding: 28rpx 24rpx 40rpx;
  background:
    radial-gradient(circle at top right, rgba(251, 191, 36, 0.22), transparent 34%),
    linear-gradient(180deg, #fff8eb 0%, #fffdf8 42%, #f7f8fc 100%);
}

.hero {
  padding: 28rpx;
  border-radius: 30rpx;
  background: linear-gradient(145deg, rgba(255, 251, 235, 0.96), rgba(255, 255, 255, 0.96));
  box-shadow: 0 18rpx 40rpx rgba(249, 115, 22, 0.10);
  border: 1rpx solid rgba(251, 191, 36, 0.28);
}

.badge {
  display: inline-flex;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #fff4cf;
  color: #b45309;
  font-size: 22rpx;
  font-weight: 700;
}

.title {
  margin-top: 20rpx;
  font-size: 42rpx;
  line-height: 1.25;
  font-weight: 700;
  color: #111827;
}

.subtitle {
  margin-top: 14rpx;
  font-size: 25rpx;
  line-height: 1.7;
  color: #5b6475;
}

.panel {
  margin-top: 24rpx;
  padding: 28rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 14rpx 34rpx rgba(15, 23, 42, 0.06);
}

.label {
  margin-top: 18rpx;
  margin-bottom: 12rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #1f2937;
}

.no-gap {
  margin-top: 0;
  margin-bottom: 8rpx;
}

.input,
.textarea {
  width: 100%;
  box-sizing: border-box;
  border-radius: 24rpx;
  border: 1rpx solid #e5e7eb;
  background: #f8fafc;
  color: #111827;
  font-size: 28rpx;
  padding: 24rpx;
}

.textarea {
  min-height: 280rpx;
}

.upload-row {
  margin-top: 22rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: #fff8eb;
  border: 1rpx dashed #f59e0b;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.hint {
  font-size: 22rpx;
  line-height: 1.6;
  color: #6b7280;
}

.upload-btn {
  margin: 0;
  padding: 0 28rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 999rpx;
  background: #111827;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 600;
}

.image-grid {
  margin-top: 18rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.preview {
  width: 100%;
  height: 200rpx;
  border-radius: 20rpx;
  background: #e5e7eb;
}

.submit-btn {
  margin-top: 28rpx;
  border-radius: 26rpx;
  background: linear-gradient(135deg, #f59e0b, #f97316 55%, #ef4444);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
}

.submit-btn[disabled] {
  opacity: 0.55;
}

.message {
  margin-top: 18rpx;
  padding: 20rpx 22rpx;
  border-radius: 20rpx;
  background: #f8fafc;
  color: #475569;
  font-size: 24rpx;
  line-height: 1.6;
}

.message.success {
  background: #ecfdf5;
  color: #047857;
}
