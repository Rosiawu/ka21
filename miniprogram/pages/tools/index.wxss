.search-row {
  display: flex;
  gap: 12rpx;
}

.search-input {
  flex: 1;
  height: 76rpx;
  border-radius: 14rpx;
  background: #f8fafc;
  border: 1rpx solid #e2e8f0;
  padding: 0 18rpx;
}

.clear-btn {
  margin: 0;
  height: 76rpx;
  line-height: 76rpx;
  border: none;
  border-radius: 14rpx;
  padding: 0 22rpx;
  background: #eef2ff;
  color: #3730a3;
  font-size: 24rpx;
}

.category-scroll {
  margin-top: 16rpx;
  width: 100%;
  white-space: nowrap;
}

.nowrap {
  display: inline-flex;
}

.tool-card {
  margin-top: 14rpx;
  border-radius: 22rpx;
  border: 2rpx solid #e2e8f3;
  background: linear-gradient(180deg, #ffffff 0%, #fcfdff 100%);
  box-shadow:
    0 14rpx 32rpx rgba(15, 23, 42, 0.08),
    0 4rpx 10rpx rgba(15, 23, 42, 0.06);
  transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
}

.tool-card-hover,
.tool-card-active {
  transform: translateY(-10rpx) scale(1.01);
  border-color: #c1cfe7;
  box-shadow:
    0 30rpx 60rpx rgba(15, 23, 42, 0.22),
    0 12rpx 24rpx rgba(15, 23, 42, 0.14);
}

.tool-row {
  align-items: flex-start;
}

.tool-icon {
  width: 78rpx;
  height: 78rpx;
  border-radius: 12rpx;
  background: #f8fafc;
  margin-right: 14rpx;
  flex-shrink: 0;
}

.tool-body {
  flex: 1;
  min-width: 0;
}

.title-row {
  align-items: flex-start;
}

.tool-name {
  font-size: 30rpx;
  font-weight: 700;
}

.tool-category {
  color: #64748b;
  font-size: 22rpx;
}

.tool-description {
  margin-top: 10rpx;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
  color: #475467;
  line-height: 1.45;
  font-size: 24rpx;
}

.badges {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  margin-top: 14rpx;
  gap: 10rpx;
}

.status-badge {
  display: inline-flex;
  flex: 0 0 auto;
  align-items: center;
  justify-content: center;
  min-width: 112rpx;
  height: 50rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  box-sizing: border-box;
  white-space: nowrap;
  overflow: hidden;
}

.status-badge-text {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 50rpx;
  text-align: center;
}

.empty-wrap {
  padding: 42rpx 0;
  text-align: center;
}

.empty-text {
  color: #64748b;
  font-size: 26rpx;
}
