.search-input {
  margin-top: 6rpx;
  height: 76rpx;
  border-radius: 14rpx;
  background: #f8fafc;
  border: 1rpx solid #e2e8f0;
  padding: 0 18rpx;
}

.filter-label {
  margin-top: 18rpx;
  margin-bottom: 10rpx;
  display: block;
  font-size: 25rpx;
  font-weight: 600;
  color: #334155;
}

.filter-scroll {
  white-space: nowrap;
}

.nowrap {
  display: inline-flex;
}

.reset-btn {
  margin-top: 18rpx;
  height: 68rpx;
  line-height: 68rpx;
  border: 1rpx solid #cbd5e1;
  border-radius: 14rpx;
  background: #ffffff;
  color: #334155;
  font-size: 25rpx;
}

.tutorial-card {
  margin-top: 10rpx;
  padding: 12rpx 10rpx 14rpx;
  border-radius: 14rpx;
  border: 1rpx solid #d8d1c3;
  background: linear-gradient(180deg, #fffefb 0%, #fcf8f1 100%);
  box-shadow:
    inset 0 0 0 1rpx #f2eadc,
    0 8rpx 18rpx rgba(92, 81, 61, 0.09);
  transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease,
    background-color 0.18s ease;
}

.tutorial-card-hover,
.tutorial-card-active {
  transform: translateY(-7rpx);
  border-color: #c7ba9e;
  background: linear-gradient(180deg, #fffefb 0%, #f9f2e7 100%);
  box-shadow:
    inset 0 0 0 1rpx #efe4d1,
    0 16rpx 30rpx rgba(92, 81, 61, 0.16);
}

.tutorial-main {
  display: flex;
  gap: 10rpx;
  align-items: flex-start;
  padding-bottom: 8rpx;
  border-bottom: 1rpx solid #ebe3d6;
}

.cover {
  width: 156rpx;
  height: 92rpx;
  border-radius: 10rpx;
  background: #f3f0ea;
  flex-shrink: 0;
  border: 1rpx solid #ddd4c6;
  box-shadow: inset 0 0 0 1rpx #f6f0e5;
}

.cover-placeholder {
  width: 156rpx;
  height: 92rpx;
  border-radius: 10rpx;
  background: linear-gradient(135deg, #f4efe4, #ebe3d4);
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cover-placeholder-text {
  color: #665b4b;
  font-size: 22rpx;
  font-weight: 600;
}

.body {
  flex: 1;
  min-width: 0;
}

.title {
  display: -webkit-box;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.35;
  letter-spacing: 0.2rpx;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.meta {
  display: block;
  margin-top: 4rpx;
  color: #8b8172;
  font-size: 21rpx;
}

.chips {
  margin-top: 6rpx;
  gap: 8rpx;
  flex-wrap: wrap;
}

.tutorial-card .badge {
  padding: 4rpx 12rpx;
  font-size: 21rpx;
  border-radius: 999rpx;
  border: 1rpx solid #dfd5c3;
  background: #fbf7ef;
  color: #685d4f;
}

.tutorial-card .badge-access-direct {
  border-color: #d7cfbe;
  background: #f7f2e8;
  color: #5d5447;
}

.tutorial-card .badge-access-proxy {
  border-color: #e0d7c9;
  background: #f4efe5;
  color: #766d60;
}

.reason {
  display: -webkit-box;
  margin-top: 7rpx;
  color: #62584c;
  font-size: 23rpx;
  line-height: 1.4;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.empty-wrap {
  padding: 42rpx 0;
  text-align: center;
}

.empty-text {
  color: #64748b;
}
