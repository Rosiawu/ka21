.search-input {
  margin-top: 6rpx;
  height: 76rpx;
  border-radius: 14rpx;
  background: #f8fafc;
  border: 1rpx solid #e2e8f0;
  padding: 0 18rpx;
}

.filter-label {
  margin-top: 18rpx;
  margin-bottom: 10rpx;
  display: block;
  font-size: 25rpx;
  font-weight: 600;
  color: #334155;
}

.filter-scroll {
  white-space: nowrap;
}

.nowrap {
  display: inline-flex;
}

.reset-btn {
  margin-top: 18rpx;
  height: 68rpx;
  line-height: 68rpx;
  border: 1rpx solid #cbd5e1;
  border-radius: 14rpx;
  background: #ffffff;
  color: #334155;
  font-size: 25rpx;
}

.tutorial-card {
  margin-top: 14rpx;
  display: flex;
  gap: 14rpx;
  border-bottom: 1rpx solid #eef2f7;
  padding-bottom: 14rpx;
}

.tutorial-card:last-child {
  border-bottom: none;
}

.cover {
  width: 188rpx;
  height: 118rpx;
  border-radius: 12rpx;
  background: #e2e8f0;
  flex-shrink: 0;
}

.body {
  flex: 1;
  min-width: 0;
}

.title {
  display: -webkit-box;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.4;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.meta {
  display: block;
  margin-top: 6rpx;
  color: #64748b;
  font-size: 22rpx;
}

.chips {
  margin-top: 8rpx;
  gap: 8rpx;
  flex-wrap: wrap;
}

.reason {
  display: -webkit-box;
  margin-top: 8rpx;
  color: #475467;
  font-size: 24rpx;
  line-height: 1.45;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.empty-wrap {
  padding: 42rpx 0;
  text-align: center;
}

.empty-text {
  color: #64748b;
}
