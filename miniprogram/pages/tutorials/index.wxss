.search-input {
  margin-top: 6rpx;
  height: 76rpx;
  border-radius: 14rpx;
  background: #f8fafc;
  border: 1rpx solid #e2e8f0;
  padding: 0 18rpx;
}

.filter-label {
  margin-top: 18rpx;
  margin-bottom: 10rpx;
  display: block;
  font-size: 25rpx;
  font-weight: 600;
  color: #334155;
}

.filter-scroll {
  white-space: nowrap;
}

.nowrap {
  display: inline-flex;
}

.reset-btn {
  margin-top: 18rpx;
  height: 68rpx;
  line-height: 68rpx;
  border: 1rpx solid #cbd5e1;
  border-radius: 14rpx;
  background: #ffffff;
  color: #334155;
  font-size: 25rpx;
}

.tutorial-card {
  margin-top: 6rpx;
  padding: 10rpx 8rpx 12rpx;
  border-radius: 16rpx;
  border: 1rpx solid transparent;
  background: transparent;
  box-shadow: none;
  transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease,
    background-color 0.18s ease;
}

.tutorial-card-hover,
.tutorial-card-active {
  transform: translateY(-6rpx);
  border-color: #e5eaf1;
  background: #ffffff;
  box-shadow:
    0 14rpx 30rpx rgba(15, 23, 42, 0.1),
    0 4rpx 10rpx rgba(15, 23, 42, 0.06);
}

.tutorial-main {
  display: flex;
  gap: 10rpx;
  align-items: flex-start;
  padding-bottom: 8rpx;
  border-bottom: 1rpx solid #edf1f5;
}

.cover {
  width: 156rpx;
  height: 92rpx;
  border-radius: 12rpx;
  background: #f3f5f7;
  flex-shrink: 0;
  border: 1rpx solid #e7edf2;
}

.cover-placeholder {
  width: 156rpx;
  height: 92rpx;
  border-radius: 12rpx;
  background: linear-gradient(135deg, #f2f6fb, #e8eff7);
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cover-placeholder-text {
  color: #4b5d72;
  font-size: 22rpx;
  font-weight: 600;
}

.body {
  flex: 1;
  min-width: 0;
}

.title {
  display: -webkit-box;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.35;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.meta {
  display: block;
  margin-top: 4rpx;
  color: #7b8798;
  font-size: 21rpx;
}

.chips {
  margin-top: 6rpx;
  gap: 8rpx;
  flex-wrap: wrap;
}

.tutorial-card .badge {
  padding: 4rpx 12rpx;
  font-size: 21rpx;
  border-radius: 999rpx;
  border: 1rpx solid #dfe6ee;
  background: #f8fafc;
  color: #516073;
}

.tutorial-card .badge-access-direct {
  border-color: #dce6f1;
  background: #f5f9fd;
  color: #4b627a;
}

.tutorial-card .badge-access-proxy {
  border-color: #e7dfd5;
  background: #faf6f0;
  color: #6b6255;
}

.reason {
  display: -webkit-box;
  margin-top: 7rpx;
  color: #556375;
  font-size: 23rpx;
  line-height: 1.4;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.empty-wrap {
  padding: 42rpx 0;
  text-align: center;
}

.empty-text {
  color: #64748b;
}
